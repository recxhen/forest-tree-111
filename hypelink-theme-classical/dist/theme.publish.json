{
  "schemaVersion": "1.0",
  "package": {
    "id": "hypelink-theme-classical",
    "name": "HypeLink Classical",
    "version": "1.0.0",
    "author": "HypeLink",
    "description": "古典風格品牌頁：襯線字型、羊皮紙質感、赭石與金色點綴，適合書齋、藝文與典藏品牌。",
    "entry": "./app/theme-entry.tsx",
    "previewImage": "./preview.png",
    "capabilities": [
      "profile",
      "social-links",
      "folder-items",
      "space-links",
      "theme-settings"
    ],
    "platform": {
      "minVersion": "1.0.0"
    }
  },
  "meta": {
    "category": "template",
    "tags": [
      "classical",
      "serif",
      "parchment",
      "art",
      "brand"
    ],
    "supportsDarkMode": false,
    "supportsMobilePreview": true,
    "recommendedFor": [
      "creator",
      "brand",
      "studio"
    ]
  },
  "motion": {
    "screen": {
      "tabTransition": "fade",
      "durationMs": 260
    },
    "enter": {
      "preset": "fade_in",
      "speed": 1
    },
    "exit": {
      "preset": "fade_out",
      "speed": 1
    },
    "continuous": {
      "preset": "none",
      "targetElement": "avatar",
      "speed": 1,
      "intensity": 0
    }
  },
  "defaultSettings": {
    "layout": "grid",
    "accentColor": "#8b2942",
    "backgroundColor": "#f5efe4",
    "showBio": true,
    "cardRadius": 12,
    "bottomBar": {
      "visibility": "always",
      "background": "rgba(252,248,238,0.78)",
      "borderColor": "rgba(196,176,138,0.65)",
      "backdropBlurPx": 14,
      "labelInactiveColor": "#7a6f5d",
      "iconActiveBackground": "rgba(166,124,0,0.14)",
      "switchCheckedBackground": "#8b2942"
    },
    "folderTabs": {
      "barBackground": "rgba(252,248,238,0.88)",
      "barBorderColor": "#c4b08a",
      "barBackdropBlurPx": 8,
      "inactiveColor": "#7a6f5d",
      "inactiveHoverColor": "#5e5648",
      "activeTextColor": "#8b2942",
      "activeIndicatorColor": "#a67c00"
    }
  },
  "assets": {
    "kind": "hypelink-theme-v2",
    "entryModule": "theme-entry.js",
    "note": "v2 ESM bundle：將 dist/esm/ 目錄上傳至 R2；公開頁會 dynamic import theme-entry.js 載入主題元件。"
  }
}